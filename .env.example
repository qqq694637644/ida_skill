# Copy this file to .env and replace placeholders with local values.
# Never commit .env. It is ignored by git.

# Public URL published in /openapi.json. Include /skills when Caddy strips that prefix.
SKILL_TEMPLE_SERVER_URL=https://gptaction.casacam.net/skills

# IDAPython skill docs from the ida-script-gptaction-version submodule.
SKILL_TEMPLE_SKILLS_DIR=C:/Users/Administrator/Desktop/ida_skill/external/ida-script-gptaction-version/src/ida_script_mcp/resources

# Optional Bearer token for GPT Action calls. Set the real secret only in .env.
# In Custom GPT Actions, configure Authentication as API Key / Bearer and paste this value.
SKILL_TEMPLE_BEARER_TOKEN=replace-with-a-long-random-secret

# IDA plugin location from the gateway process. 127.0.0.1 means the same host.
IDA_SCRIPT_MCP_HOST=127.0.0.1

# Usually leave unset so the gateway can auto-discover running IDA instances.
# IDA_SCRIPT_MCP_PORT=13338
